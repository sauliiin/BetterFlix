<?xml version="1.0" encoding="utf-8"?>
<window>
	<onload condition="Player.HasVideo + String.StartsWith(Player.Duration(hh:mm:ss), &quot;00:0&quot;) + Skin.HasSetting(dstv_enable_auto_trailer)">PlayerControl(Stop)</onload>
	<onload condition="!Player.PauseEnabled">SetFocus(603)</onload>
	<defaultcontrol always="true">602</defaultcontrol>
	<depth>DepthOSD</depth>
	<controls>
		<control type="button">
			<description>background close area</description>
			<left>0</left>
			<top>0</top>
			<width>100%</width>
			<bottom>280</bottom>
			<texturefocus />
			<texturenofocus />
			<onclick>Action(close)</onclick>
		</control>
		<include condition="Skin.HasSetting(touchmode)">TouchBackOSDButton</include>
		<control type="group">
			<animation type="WindowOpen" reversible="False">
				<effect type="fade" start="0" end="100" />
			</animation>
			<bottom>0</bottom>
			<height>200</height>
			<visible>![Window.IsVisible(SliderDialog) | Window.IsVisible(1110) | Window.IsVisible(osdaudiosettings) | Window.IsVisible(osdvideosettings) | Window.IsVisible(VideoBookmarks) | Window.IsVisible(playerprocessinfo) | Window.IsVisible(osdcmssettings) | Window.IsVisible(PVROSDChannels) | Window.IsVisible(pvrchannelguide)]</visible>
			<animation effect="fade" time="300">VisibleChange</animation>
			<control type="group" id="200">

				<control type="grouplist" id="201">
					<include>Animation_BottomSlide</include>
					<left>133</left>
					<top>27</top>
					<width>100%</width>
					<height>135</height>
					<itemgap>10</itemgap>
					<scrolltime tween="sine">200</scrolltime>
					<orientation>horizontal</orientation>
					<onup>87</onup>
					<ondown>noop</ondown>
					<onleft>70048</onleft>
					<onright>804</onright>
					<control type="group" id="698">
						<width>76</width>
						<height>76</height>
						<visible>Player.PauseEnabled</visible>
						<control type="button" id="602">
							<left>0</left>
							<top>0</top>
							<width>52</width>
							<height>52</height>
							<label></label>
							<font></font>
							<texturefocus colordiffuse="selected">dstv/osd/button-fo.png</texturefocus>
							<texturenofocus />
							<onright>87</onright>
							<onleft>87</onleft>
							<ondown>202</ondown>
							<onup>202</onup>
							<onclick>PlayerControl(Play)</onclick>
						</control>
						<control type="image">
							<left>5</left>
							<top>14</top>
							<width>85</width>
							<height>85</height>
							<animation center="auto" effect="zoom" end="115" reversible="false" start="85" time="300" tween="sine" condition="Control.HasFocus(602)">Conditional</animation>
							<animation center="auto" effect="zoom" end="85" reversible="true" start="115" time="300" delay="300" tween="sine" condition="Control.HasFocus(602)">Conditional</animation>
							<texture colordiffuse="white">$VAR[PlayerControlsPlayImageVar]</texture>
						</control>
					</control>
				</control>
				<control type="image" id="70042">
					<left>56</left>
					<top>-823</top>
					<width>46</width>
					<height>46</height>
					<include>Animation_TopSlide</include>
					<texture>dstv/jedi/cog.png</texture>
					<animation effect="rotate" start="0" end="360" condition="true" center="auto" time="1800" delay="2000" pulse="true">Conditional</animation>
					<animation effect="fade" start="100" end="0" time="100" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
				</control>
				<control type="grouplist" id="202">
					<left>50</left>
					<top>-830</top>
					<width>500</width>
					<height>135</height>
					<align>left</align>
					<itemgap>10</itemgap>
					<include>Animation_TopSlide</include>
					<scrolltime tween="sine">200</scrolltime>
					<orientation>horizontal</orientation>
					<ondown>602</ondown>
					<onup>602</onup>
					<animation effect="fade" start="100" end="0" time="500" condition="!Control.HasFocus(70043) + !Control.HasFocus(70046) + !Control.HasFocus(70048) + !Control.HasFocus(70049)">Conditional</animation>

					<!-- Botão Legendas -->
					<control type="radiobutton" id="70043">
						<include content="OSDButton">
							<param name="texture" value="dstv/jedi/subtitles.png"/>
							<param name="texture_focus" value="dstv/jedi/subtitles_fo.png"/>
							<param name="texture_nofocus" value="dstv/jedi/subtitles.png"/>
						</include>
						<visible>true</visible>
						<animation effect="fade" start="0" end="100" time="200" reversible="true" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
						<animation effect="zoom" start="0" end="100" center="left" time="200" reversible="true" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
						<onclick>ActivateWindow(osdsubtitlesettings)</onclick>
						<animation center="38,38" effect="zoom" end="110" reversible="false" start="80" time="500" tween="back" condition="Control.HasFocus(70043)">Conditional</animation>
					</control>

					<!-- Botão Áudio -->
					<control type="radiobutton" id="70046">
						<include content="OSDButton">
							<param name="texture" value="dstv/jedi/audio.png"/>
							<param name="texture_focus" value="dstv/jedi/audio_fo.png"/>
							<param name="texture_nofocus" value="dstv/jedi/audio.png"/>
						</include>
						<visible>true</visible>
						<animation effect="fade" start="0" end="100" time="250" delay="50" reversible="true" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
						<animation effect="zoom" start="0" end="100" center="left" time="250" delay="50" reversible="true" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
						<onclick>ActivateWindow(osdaudiosettings)</onclick>
						<animation center="38,38" effect="zoom" end="110" reversible="false" start="80" time="500" tween="back" condition="Control.HasFocus(70046)">Conditional</animation>
					</control>

					<!-- Botão Info -->
					<control type="radiobutton" id="70048">
						<include content="OSDButton">
							<param name="texture" value="dstv/jedi/info.png"/>
							<param name="texture_focus" value="dstv/jedi/info_fo.png"/>
							<param name="texture_nofocus" value="dstv/jedi/info.png"/>
						</include>
						<visible>true</visible>
						<animation effect="fade" start="0" end="100" time="300" delay="100" reversible="true" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
						<animation effect="zoom" start="0" end="100" center="left" time="300" delay="100" reversible="true" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
						<onclick>ActivateWindow(fullscreeninfo)</onclick>
						<animation center="38,38" effect="zoom" end="110" reversible="false" start="80" time="500" tween="back" condition="Control.HasFocus(70048)">Conditional</animation>
					</control>

					<!-- Botão Vídeo -->
					<control type="radiobutton" id="70049">
						<include content="OSDButton">
							<param name="texture" value="dstv/jedi/video.png"/>
							<param name="texture_focus" value="dstv/jedi/video_fo.png"/>
							<param name="texture_nofocus" value="dstv/jedi/video.png"/>
						</include>
						<visible>true</visible>
						<animation effect="fade" start="0" end="100" time="350" delay="150" reversible="true" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
						<animation effect="zoom" start="0" end="100" center="left" time="350" delay="150" reversible="true" condition="Control.HasFocus(70043) | Control.HasFocus(70046) | Control.HasFocus(70048) | Control.HasFocus(70049)">Conditional</animation>
						<onclick>ActivateWindow(osdvideosettings)</onclick>
						<animation center="38,38" effect="zoom" end="110" reversible="false" start="80" time="500" tween="back" condition="Control.HasFocus(70049)">Conditional</animation>
					</control>
				</control>
			</control>
			<control type="group" id="6000">
				<top>60</top>
				<include>Animation_BottomSlide</include>

				<visible>Player.SeekEnabled</visible>
				<control type="button" id="87">
					<include>HiddenObject</include>
					<onup>200</onup>
					<ondown>200</ondown>
					<onleft>StepBack</onleft>
					<onright condition="!Player.Paused">StepForward</onright>
					<onright condition="Player.Paused">PlayerControl(FrameAdvance(1))</onright>
				</control>
				<!-- Progress Bar Background (Cache) -->
				<control type="slider">
					<top>-5</top>
					<left>0</left>
					<width>100%</width>
					<height>36</height>
					<texturesliderbar colordiffuse="00FFFFFF">osd/progress/nub_leftright.png</texturesliderbar>
					<textureslidernib colordiffuse="button_focus">osd/progress/nub_leftright.png</textureslidernib>
					<textureslidernibfocus colordiffuse="button_focus">osd/progress/nub_leftright.png</textureslidernibfocus>
					<info>Player.Progress</info>
					<onup>200</onup>
					<ondown>200</ondown>
					<action>seek</action>
					<visible>Control.HasFocus(87) + !VideoPlayer.Content(LiveTV)</visible>
				</control>
				<control type="slider">
					<top>-5</top>
					<left>0</left>
					<width>100%</width>
					<height>36</height>
					<texturesliderbar colordiffuse="00FFFFFF">osd/progress/nub_leftright.png</texturesliderbar>
					<textureslidernib>osd/progress/nub_leftright.png</textureslidernib>
					<textureslidernibfocus colordiffuse="button_focus">osd/progress/nub_leftright.png</textureslidernibfocus>
					<info>PVR.TimeshiftProgressPlayPos</info>
					<onup>200</onup>
					<ondown>200</ondown>
					<action>pvr.seek</action>
					<visible>!Control.HasFocus(87) + VideoPlayer.Content(LiveTV)</visible>
				</control>
				<control type="slider">
					<top>-5</top>
					<left>0</left>
					<width>100%</width>
					<height>36</height>
					<texturesliderbar colordiffuse="00FFFFFF">osd/progress/nub_leftright.png</texturesliderbar>
					<textureslidernib colordiffuse="button_focus">osd/progress/nub_leftright.png</textureslidernib>
					<textureslidernibfocus colordiffuse="button_focus">osd/progress/nub_leftright.png</textureslidernibfocus>
					<info>PVR.TimeshiftProgressPlayPos</info>
					<onup>200</onup>
					<ondown>200</ondown>
					<action>pvr.seek</action>
					<visible>Control.HasFocus(87) + VideoPlayer.Content(LiveTV)</visible>
				</control>
			</control>
		</control>
		<control type="group">
			<visible>![Window.IsVisible(SliderDialog) | Window.IsVisible(1110) | Window.IsVisible(osdaudiosettings) | Window.IsVisible(osdvideosettings) | Window.IsVisible(VideoBookmarks) | Window.IsVisible(playerprocessinfo) | Window.IsVisible(osdcmssettings) | Window.IsVisible(PVROSDChannels) | Window.IsVisible(pvrchannelguide)]</visible>
			<include>Animation_TopSlide</include>
			<animation effect="fade" time="300">VisibleChange</animation>

			<!-- Clearlogo -->
			<control type="grouplist">
				<visible>!String.IsEmpty(Player.Art(tvshow.clearlogo)) | !String.IsEmpty(Player.Art(clearlogo))</visible>
				<top>20</top>
				<height>10%</height>
				<align>center</align>
				<aligny>center</aligny>
				<itemgap>10</itemgap>
				<orientation>horizontal</orientation>
				<control type="image">
					<width>300</width>
					<aspectratio>keep</aspectratio>
					<texture>$VAR[PlayerClearLogoVar]</texture>
				</control>
			</control>

			<!-- Custom Season/Episode -->
			<control type="label">
				<top>-785</top>
				<width>100%</width>
				<align>center</align>
				<aligny>center</aligny>
				<font>fontOSDt</font>
				<visible>!String.IsEmpty(VideoPlayer.Season)</visible>
				<label>Temporada $INFO[VideoPlayer.Season]  •  Episódio $INFO[VideoPlayer.Episode]</label>
			</control>

			<!-- Clock -->
			<control type="label">
				<font>font_clock</font>
				<shadowcolor>text_shadow</shadowcolor>
				<top>15</top>
				<right>35</right>
				<height>200</height>
				<width>600</width>
				<align>right</align>
				<label>$INFO[System.Time]</label>
			</control>

			<!-- Finish Time -->
			<control type="grouplist">
				<right>40</right>
				<top>95</top>
				<width>800</width>
				<height>100</height>
				<align>right</align>
				<itemgap>5</itemgap>
				<orientation>horizontal</orientation>
				<usecontrolcoords>true</usecontrolcoords>
				<visible>!String.isempty(Player.Duration)</visible>
				<control type="label">
					<label>$INFO[Player.FinishTime,$LOCALIZE[31080]: ]</label>
					<shadowcolor>text_shadow</shadowcolor>
					<height>100</height>
					<width>auto</width>
					<font>font27l</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + ![Player.HasGame | VideoPlayer.HasEpg]</visible>
				</control>
				<control type="label">
					<label>$INFO[PVR.EpgEventFinishTime,$LOCALIZE[31080]: ]</label>
					<shadowcolor>text_shadow</shadowcolor>
					<height>100</height>
					<width>auto</width>
					<font>font27l</font>
					<shadowcolor>black</shadowcolor>
					<visible>VideoPlayer.HasEpg</visible>
				</control>
			</control>
		</control>

		<!-- Bottom Elements Group (Time / Remaining) -->
		<control type="group">
			<visible>![Window.IsVisible(SliderDialog) | Window.IsVisible(1110) | Window.IsVisible(osdaudiosettings) | Window.IsVisible(osdvideosettings) | Window.IsVisible(VideoBookmarks) | Window.IsVisible(playerprocessinfo) | Window.IsVisible(osdcmssettings) | Window.IsVisible(PVROSDChannels) | Window.IsVisible(pvrchannelguide)]</visible>
			<!-- Slide when Playing -->
			<animation type="WindowOpen" reversible="False" condition="!Player.Paused + !Window.IsActive(fullscreeninfo)">
				<effect type="fade" start="0" end="100" time="400"/>
				<effect type="slide" start="0,200" end="0,0" time="400" tween="sine" easing="inout" />
			</animation>
			<animation type="WindowClose" condition="!Player.Paused + !Window.IsActive(fullscreeninfo)" reversible="False">
				<effect type="fade" start="100" end="0" time="400"/>
				<effect type="slide" start="0,0" end="0,200" time="500" tween="sine" easing="inout" />
			</animation>

			<!-- Fade when Paused -->
			<animation type="WindowOpen" reversible="False" condition="Player.Paused | Window.IsActive(fullscreeninfo)">
				<effect type="fade" start="0" end="100" time="300"/>
			</animation>
			<animation type="WindowClose" condition="Player.Paused | Window.IsActive(fullscreeninfo)" reversible="False">
				<effect type="fade" start="100" end="0" time="300"/>
			</animation>

			<!-- Time -->
			<control type="label">
				<top>941</top>
				<left>235</left>
				<width>134</width>
				<height>60</height>
				<label>$INFO[Player.Time]</label>
				<font>fontOSD</font>
				<align>center</align>
				<shadowcolor>black</shadowcolor>
				<visible>!Player.ChannelPreviewActive | VideoPlayer.HasEpg</visible>
			</control>

			<!-- Time Remaining -->
			<control type="label">
				<top>941</top>
				<left>1529</left>
				<width>134</width>
				<height>60</height>
				<label>$INFO[Player.TimeRemaining]</label>
				<font>fontOSD</font>
				<align>center</align>
				<shadowcolor>black</shadowcolor>
				<visible>!Player.ChannelPreviewActive | VideoPlayer.HasEpg</visible>
			</control>

		</control>
	</controls>
</window>

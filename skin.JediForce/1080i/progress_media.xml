<?xml version="1.0" encoding="UTF-8"?>
<window>
	<onload condition="!Window.IsActive(home)">Action(close)</onload>
	<defaultcontrol always="true">9000</defaultcontrol>
	<controls>
		<control type="group">
			<visible>Window.IsActive(home)</visible>
			<animation effect="fade" start="0" end="100" time="500" tween="sine" easing="out">WindowOpen</animation>
			<control type="button" id="9000">
				<left>0</left>
				<top>0</top>
				<width>100%</width>
				<height>100%</height>
				<onleft>9000</onleft>
				<onright>9000</onright>
				<onup>9000</onup>
				<ondown>9000</ondown>
				<texturefocus />
				<texturenofocus />
				<onclick>noop</onclick>
			</control>

			<control type="group">
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>1920</width>
                    <height>1080</height>
                    <texture>black.png</texture>
                </control>
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>1920</width>
                    <height>1080</height>
                    <texture>$INFO[Window.Property(tikiskins.source_progress.fanart)]</texture>
                    <animation effect="fade" start="0" end="100" time="0" tween="sine">WindowOpen</animation>
                </control>
			</control>
            <control type="image">
                <animation effect="fade" start="100" end="0" time="1200" pulse="true" condition="true">Conditional</animation>
                <width>35%</width>
                <height>290</height>
                <aspectratio>keep</aspectratio>
                <texture>$INFO[Window(Home).Property(ds_info_clearlogo)]</texture>
                <visible>!Player.HasVideo | [Player.HasVideo + String.IsEmpty(Player.Art(tvshow.clearlogo)) + String.IsEmpty(Player.Art(clearlogo))]</visible>
                <centerleft>50%</centerleft>
                <centertop>35%</centertop>
            </control>
            <control type="image">
                <animation effect="fade" start="100" end="0" time="1200" pulse="true" condition="true">Conditional</animation>
                <width>35%</width>
                <height>290</height>
                <aspectratio>keep</aspectratio>
                <texture>$VAR[PlayerClearLogoVar]</texture>
                <visible>Player.HasVideo + [!String.IsEmpty(Player.Art(tvshow.clearlogo)) | !String.IsEmpty(Player.Art(clearlogo))]</visible>
                <centerleft>50%</centerleft>
                <centertop>35%</centertop>
            </control>

            <control type="label">
                <centerleft>50%</centerleft>
                <centertop>74.4%</centertop>
                <visible>!Player.HasVideo | [Player.HasVideo + String.IsEmpty(VideoPlayer.Season) + String.IsEmpty(VideoPlayer.Tagline)]</visible>
                <label>$VAR[ds_infoTagline]</label>
                <font>netBb</font>
                <align>center</align>
            </control>
            <control type="label">
                <centerleft>50%</centerleft>
                <centertop>74.4%</centertop>
                <visible>Player.HasVideo + String.IsEmpty(VideoPlayer.Season) + !String.IsEmpty(VideoPlayer.Tagline)</visible>
                <label>$INFO[VideoPlayer.Tagline]</label>
                <font>netBb</font>
                <align>center</align>
            </control>

            <control type="label">
                <centerleft>50%</centerleft>
                <centertop>74.4%</centertop>
                <visible>Player.HasVideo + !String.IsEmpty(VideoPlayer.Season)</visible>
                <label>Temporada $INFO[VideoPlayer.Season]  •  Episódio $INFO[VideoPlayer.Episode]</label>
                <font>netS</font>
                <align>center</align>
            </control>

            <control type="textbox">
                <visible>!Player.HasVideo | [Player.HasVideo + String.IsEmpty(VideoPlayer.Plot)]</visible>
                <label>$VAR[ds_infoDescription]</label>
                <centerleft>50%</centerleft>
                <centertop>69.1%</centertop>
                <width>915</width>
                <height>350</height>
                <font>netSpov</font>
                <shadowcolor>FF000000</shadowcolor> 
                <shadowoffsetx>3</shadowoffsetx> 
                <shadowoffsety>3</shadowoffsety> 
                <align>center</align> 
            </control>
            <control type="textbox">
                <visible>Player.HasVideo + !String.IsEmpty(VideoPlayer.Plot)</visible>
                <label>$INFO[VideoPlayer.Plot]</label>
                <centerleft>50%</centerleft>
                <centertop>69.1%</centertop>
                <width>915</width>
                <height>350</height>
                <font>netSpov</font>
                <shadowcolor>FF000000</shadowcolor> 
                <shadowoffsetx>3</shadowoffsetx> 
                <shadowoffsety>3</shadowoffsety> 
                <align>center</align> 
            </control>

		</control>
	</controls>
</window>

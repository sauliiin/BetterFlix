								<aspectratio>scale</aspectratio>
								<visible>Control.HasFocus(6001)</visible>
							</control>
							<control type="image">
								<left>10</left>
								<top>35</top>
								<width>220</width>
								<height>320</height>
								<texture fallback="DefaultVideo.png">$INFO[ListItem.Icon]</texture>
								<aspectratio>scale</aspectratio>
								<bordertexture border="21">colors/black.png</bordertexture>
							</control>
							<control type="label">
								<left>10</left>
								<top>0</top>
								<width>220</width>
								<height>30</height>
								<font>font9</font>
								<align>center</align>
								<shadowcolor>FF000000</shadowcolor>
								<label>$INFO[ListItem.Label] ($INFO[ListItem.Label2])</label>
								<scroll>true</scroll>
							</control>
						</control>
					</focusedlayout>
				</control>

				<!-- ======================================== -->
				<!-- BIO/BIOGRAFIA + SINOPSE OVERLAY -->
				<!-- Abaixo dos posters, no mesmo espaço -->
				<!-- ======================================== -->
				<control type="group">
					<right>50</right>
					<top>700</top>
					<width>480</width>
					<height>330</height>
					<control type="image">
						<left>-5</left>
						<top>-5</top>
						<width>490</width>
						<height>330</height>
						<texture colordiffuse="4D000000">colors/white.png</texture>
						<visible>!String.IsEmpty(Window(Home).Property(ds_cast_bios)) | !String.IsEmpty(Container(50).ListItem.Property(Bio)) | !String.IsEmpty(Container(6001).ListItem.Property(Overview))</visible>
					</control>

					<!-- Estado 1: Bio resumida (cast sem foco, sem filme focado) -->
					<control type="textbox">
						<visible>!Control.HasFocus(50) + !Control.HasFocus(6001) + !String.IsEmpty(Window(Home).Property(ds_cast_bios))</visible>
						<animation effect="fade" time="500">VisibleChange</animation>
						<width>480</width>
						<height>308</height>
						<font>font9</font>
						<textcolor>white</textcolor>
						<label>$INFO[Window(Home).Property(ds_cast_bios)]</label>
						<autoscroll delay="3000" repeat="5000" time="2500"></autoscroll>
					</control>

					<!-- Estado 2: Bio do ator focado (cast COM foco) -->
					<control type="textbox">
						<visible>[Control.HasFocus(50) | Control.HasFocus(6001)] + !Control.HasFocus(6001) + !String.IsEmpty(Container(50).ListItem.Property(Bio))</visible>
						<animation effect="fade" time="500">VisibleChange</animation>
						<width>480</width>
						<height>308</height>
						<font>font10</font>
						<textcolor>white</textcolor>
						<align>justify</align>
						<label>$INFO[Container(50).ListItem.Property(Bio)][CR][CR]$INFO[Container(50).ListItem.Property(Biography)]</label>
						<autoscroll delay="3000" repeat="5000" time="2500"></autoscroll>
					</control>

					<!-- Estado 3: Sinopse do filme FILMOGRAFIA focado (se sobrepõe à bio) -->
					<control type="textbox">
						<visible>Control.HasFocus(6001) + !String.IsEmpty(Container(6001).ListItem.Property(Overview))</visible>
						<animation effect="fade" time="600">VisibleChange</animation>
						<width>480</width>
						<height>308</height>
						<align>justify</align>
						<font>font10</font>
						<textcolor>white</textcolor>
						<align>justify</align>
						<label>[B]$INFO[Container(6001).ListItem.Label][/B][CR][CR]$INFO[Container(6001).ListItem.Property(Overview)]</label>
						<autoscroll delay="4000" repeat="5000" time="3000"></autoscroll>
					</control>
				</control>
			</control>
			<control type="label">
				<right>80</right>
				<top>970</top>
				<align>right</align>
				<width>1400</width>
				<height>44</height>
				<font>font20_title</font>
				<textcolor>99FFFFFF</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<haspath>true</haspath>
				<label>$VAR[VideoInfoBottomLabelVar]</label>
				<visible>Control.HasFocus(6)</visible>
				<animation effect="fade" start="0" end="100" time="300" delay="300">WindowOpen</animation>
				<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
				<animation effect="fade" start="0" end="100" time="300">Visible</animation>
				<animation effect="fade" start="100" end="0" time="200">Hidden</animation>
			</control>
			<control type="group">
				<top>5</top>
				<left>980</left>
				<width>800</width>
				<height>44</height>
				<visible>Control.HasFocus(50)</visible>
				<control type="label">
					<left>-40</left>
					<width>auto</width>
					<height>44</height>
					<font>font12</font>
					<shadowcolor>text_shadow</shadowcolor>
					<label>Pressione </label>
				</control>
				<control type="label">
					<left>76</left>
					<width>auto</width>
					<height>44</height>
					<font>font12</font>
					<shadowcolor>text_shadow</shadowcolor>
					<label>[B]↓[/B]</label>
					<animation effect="slide" start="0,0" end="0,5" time="300" tween="sine" easing="inout" pulse="true" condition="true">Conditional</animation>
				</control>
				<control type="label">
					<left>95</left>
					<width>auto</width>
					<height>44</height>
					<font>font12</font>
					<shadowcolor>text_shadow</shadowcolor>
					<label> para visualizar a filmografia do ator</label>
				</control>
			</control>
		</control>
	</controls>
</window>
